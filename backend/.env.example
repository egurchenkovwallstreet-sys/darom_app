# Скопируй этот файл: copy .env.example .env
# Значения ниже совпадают с docker-compose.yml

PORT=3000
DATABASE_URL=postgresql://darom:darom_dev@127.0.0.1:5433/darom

# Публичный URL сайта (для редиректов Робокассы)
PUBLIC_BASE_URL=https://darom-app.online

# SMS — SMS Aero Mobile ID (рекомендуется) или обычные SMS
SMS_PROVIDER=smsaero
SMS_AERO_EMAIL=
SMS_AERO_API_KEY=
SMS_AERO_SIGN=SMS Aero
SMS_AUTH_MODE=mobile_id
SMS_AERO_MOBILE_ID_SIGN=
# sms — принудительно старый канал sms/send; mobile_id — дешевле (~3–6 ₽)
# Запасной вариант — SMS.ru
SMS_RU_API_ID=
SMS_MOCK=true

# Секрет в URL webhook Mobile ID (обязательно на боевом сервере при SMS_MOCK=false)
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
MOBILE_ID_WEBHOOK_SECRET=

# CORS — через запятую; по умолчанию darom-app.online и localhost:8080
# CORS_ORIGINS=https://darom-app.online,http://localhost:8080
# Если ключи заполнены — фото уходят в облако. Иначе — локально в backend/uploads
PHOTO_STORAGE=s3
YC_S3_BUCKET=
YC_S3_ACCESS_KEY=
YC_S3_SECRET_KEY=
YC_S3_ENDPOINT=https://storage.yandexcloud.net
YC_S3_REGION=ru-central1
# Публичный URL бакета, например: https://storage.yandexcloud.net/ваш-бакет
YC_S3_PUBLIC_BASE_URL=

# Лимиты
PHOTO_MAX_MB=5
PHOTO_MAX_COUNT=5
PHOTO_MOCK_MODERATION=true

# Yandex Vision — модерация фото (обязательно на сервере: PHOTO_MOCK_MODERATION=false)
YC_VISION_API_KEY=
# Необязательно для Api-Key сервисного аккаунта; можно указать ID каталога Yandex Cloud
YC_FOLDER_ID=
# Порог 0–1: выше — строже (по умолчанию 0.6)
YC_VISION_MODERATION_THRESHOLD=0.6

# --- Боевой сервер (I-C): SMS_MOCK=false, ADMIN_EMAIL_MOCK=false, PUSH_MOCK=false
# PAYMENT_MOCK=false — когда Робокасса одобрена и ключи заполнены; иначе можно оставить true
PUBLIC_BASE_URL=https://darom-app.online
# ADMIN_SECRET — устарел (I-C), выплаты только через admin token
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=
ROBOKASSA_TEST_PASSWORD1=
ROBOKASSA_TEST_PASSWORD2=
ROBOKASSA_TEST_MODE=false
# Чек 54-ФЗ (облачная касса Robokassa) — не отключать на бою
ROBOKASSA_FISCAL=true
ROBOKASSA_RECEIPT_TAX=none
# ROBOKASSA_SNO=usn_income
PAYMENT_MOCK=true

# Автодеплой Flutter Web (GitHub Actions → POST /api/deploy-web)
DEPLOY_SECRET=
WEB_ROOT=/var/www/darom

# --- Админ-панель (2FA: Mobile ID + код на почту) ---
ADMIN_PHONE=79138931428
ADMIN_EMAIL=e.gurchenkov@yandex.ru
# true — код на экране и в логах (для ПК); false — реальное письмо через SMTP
ADMIN_EMAIL_MOCK=true
# Если SMTP заблокирован хостингом — второй код (6 цифр) уйдёт SMS на ADMIN_PHONE
ADMIN_EMAIL_SMS_FALLBACK=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Необязательно; по умолчанию SMTP_USER
SMTP_FROM=

# --- Firebase Cloud Messaging (push-уведомления) ---
PUSH_MOCK=true
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_WEB_VAPID_KEY=
