# Скопируй этот файл: copy .env.example .env
# Значения ниже совпадают с docker-compose.yml

PORT=3000
DATABASE_URL=postgresql://darom:darom_dev@127.0.0.1:5433/darom

# Публичный URL сайта (для редиректов Робокассы)
PUBLIC_BASE_URL=https://darom-app.online

# SMS — SMS Aero Mobile ID (рекомендуется) или обычные SMS
SMS_PROVIDER=smsaero
SMS_AERO_EMAIL=
SMS_AERO_API_KEY=
SMS_AERO_SIGN=SMS Aero
SMS_AUTH_MODE=mobile_id
SMS_AERO_MOBILE_ID_SIGN=
# sms — принудительно старый канал sms/send; mobile_id — дешевле (~3–6 ₽)
# Запасной вариант — SMS.ru
SMS_RU_API_ID=
SMS_MOCK=true

# --- Фото: Yandex Object Storage ---
# Если ключи заполнены — фото уходят в облако. Иначе — локально в backend/uploads
PHOTO_STORAGE=s3
YC_S3_BUCKET=
YC_S3_ACCESS_KEY=
YC_S3_SECRET_KEY=
YC_S3_ENDPOINT=https://storage.yandexcloud.net
YC_S3_REGION=ru-central1
# Публичный URL бакета, например: https://storage.yandexcloud.net/ваш-бакет
YC_S3_PUBLIC_BASE_URL=

# Лимиты
PHOTO_MAX_MB=5
PHOTO_MAX_COUNT=5
PHOTO_MOCK_MODERATION=true

# Yandex Vision (боевой режим — позже)
YC_VISION_API_KEY=

# --- Робокасса ---
# Пока ключи пустые или PAYMENT_MOCK=true — оплата тестовая (без списания).
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=
ROBOKASSA_TEST_PASSWORD1=
ROBOKASSA_TEST_PASSWORD2=
ROBOKASSA_TEST_MODE=true
PAYMENT_MOCK=true

# Автодеплой Flutter Web (GitHub Actions → POST /api/deploy-web)
DEPLOY_SECRET=
WEB_ROOT=/var/www/darom

# --- Админ-панель (2FA: Mobile ID + код на почту) ---
ADMIN_PHONE=79138931428
ADMIN_EMAIL=e.gurchenkov@yandex.ru
# true — код на экране и в логах (для ПК); false — реальное письмо через SMTP
ADMIN_EMAIL_MOCK=true
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# Необязательно; по умолчанию SMTP_USER
SMTP_FROM=
